pindi collatzSteps(pidi n){
    pidi steps = 0;

    ittuthiri n != 1 {
        nok steps > 100 {
            poda steps;
        };

        nok n % 2 == 0 {
            n = n / 2;
        } :umbi {
            n = n * 3 + 1;
        };

        steps = steps + 1;
    }

    poda steps;
}


pindi complexTest(pidi x){
    pidi a = collatzSteps(x);
    pidi b = collatzSteps(x + 1);
    pidi c = collatzSteps(x + 2);

    nok a > b {
        nok a > c {
            poda a;
        } :umbi {
            poda c;
        };
    } :umbi {
        nok b > c {
            poda b;
        } :umbi {
            poda c;
        };
    };
}


pidi r1 = complexTest(6);
pidi r2 = complexTest(7);
pidi r3 = complexTest(8);

para r1 koode "\n";
para r2 koode "\n";
para r3 koode "\n";
