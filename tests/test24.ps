pindi assert(pidi cond_a, pidi msg_a){
    nok cond_a == thettu {
        para "FAIL: " koode msg_a koode "\n";
        poda;
    };
};

para "Starting tests...\n";

?
# -------------------------
# 1. VARIABLES
# -------------------------
?

pidi a1 = 10;
pidi b1 = 20;
assert(a1 + b1 == 30, "Variable addition failed");

a1 = 5;
assert(a1 == 5, "Variable reassignment failed");

?
# -------------------------
# 2. ARRAYS
# -------------------------
?

pidi arr1 kootam = {1,2,3};
assert(arr1[0] == 1, "Array index failed");

arr1[1] = 10;
assert(arr1[1] == 10, "Array update failed");

?
# -------------------------
# 3. STRINGS
# -------------------------
?

pidi s1 = "hello";
assert(s1[0] == "h", "String index failed");

?
# -------------------------
# 4. LOOPS
# -------------------------
?

pidi i1 = 0;
pidi sum1 = 0;
ittuthiri i1 < 5 {
    sum1 = sum1 + i1;
    i1 = i1 + 1;
};
assert(sum1 == 10, "Loop failed");

?
# -------------------------
# 5. CONDITIONALS
# -------------------------
?

pidi x1 = 10;
nok x1 > 5 {
    x1 = 100;
} :umbi {
    x1 = 0;
};
assert(x1 == 100, "If condition failed");

?
# -------------------------
# 6. FUNCTIONS
# -------------------------
?

pindi add1(pidi x2, pidi y2){
    poda x2 + y2;
};
assert(add1(2,3) == 5, "Function failed");

?
# -------------------------
# 7. RECURSION
# -------------------------
?

pindi fact1(pidi n1){
    nok n1 == 0 {
        poda 1;
    };
    poda n1 * fact1(n1-1);
};
assert(fact1(5) == 120, "Recursion failed");

?
# -------------------------
# 8. CLOSURES (VERY IMPORTANT)
# -------------------------
?

pindi outer1(pidi x3){
    pindi inner1(pidi y3){
        poda x3 + y3;
    };
    poda inner1;
};

pidi f3 = outer1(10);
assert(f3(5) == 15, "Closure failed");

?
# -------------------------
# 9. NESTED CLOSURES
# -------------------------
?

pindi A1(pidi x4){
    pindi B1(pidi y4){
        pindi C1(pidi z4){
            poda x4 + y4 + z4;
        };
        poda C1;
    };
    poda B1;
};

pidi f4 = A1(1);
pidi f5 = f4(2);
assert(f5(3) == 6, "Nested closure failed");

?
# -------------------------
# 10. ARRAY + FUNCTION
# -------------------------
?

pindi sumArr1(pidi arr2 kootam){
    pidi i2 = 0;
    pidi s2 = 0;
    ittuthiri i2 < arr2:valupam {
        s2 = s2 + arr2[i2];
        i2 = i2 + 1;
    };
    poda s2;
};

pidi te kootam = {1,2,3};
assert(sumArr1(te) == 6, "Array + function failed");

?
# -------------------------
# 11. STRESS LOOP
# -------------------------
?

pidi j1 = 0;
ittuthiri j1 < 1000 {
    j1 = j1 + 1;
};
assert(j1 == 1000, "Stress loop failed");

?
# -------------------------
# 12. MIXED TEST
# -------------------------
?

pindi mix1(pidi n2){
    pidi i3 = 0;
    pidi s3 = 0;
    ittuthiri i3 <= n2 {
        nok i3 % 2 == 0 {
            s3 = s3 + i3;
        };
        i3 = i3 + 1;
    };
    poda s3;
};

assert(mix1(5) == 6, "Mixed logic failed");

?
# -------------------------
# FINAL
# -------------------------
?

para "All tests passed!\n";
