? dataset ?
pidi data kootam = {9,4,7,1,3,6,2,8,5};

para "Original Array:";
para data:valupam;

? bubble sort algorithm ?
pindi bubbleSort(pidi arr kootam){
    pidi n = arr:valupam;
    pidi i = 0;
    ittuthiri i < n {
        pidi j = 0;
        ittuthiri j < n-1 {
            nok arr[j] > arr[j+1] {
                pidi temp = arr[j];
                arr[j] = arr[j+1];
                arr[j+1] = temp;
            };
            j = j + 1;
        }
        i = i + 1;
    }
    poda arr;
}


? binary search algorithm ?
pindi binarySearch(pidi arr kootam, pidi target){
    pidi low = 0;
    pidi high = arr:valupam - 1;
	pidi mid = -1;

    ittuthiri low <= high {
        mid = (low + high) / 2;
        nok arr[mid] == target {
            poda mid;
        }
        :nok arr[mid] < target {
            low = mid + 1;
        }
        :umbi{
            high = mid - 1;
        };
    }
    poda -1;
}


? recursive fibonacci ?
pindi fib(pidi n){
    nok n < 2 {
        poda n;
    };
    poda fib(n-1) + fib(n-2);
}

? compute sum of array ?
pindi arraySum(pidi arr kootam){
    pidi i = 0;
    pidi total = 0;

    ittuthiri i < arr:valupam {
        total = total + arr[i];
        i = i + 1;
    }
    poda total;
}

? program execution ?

para "\nSorting Array...\n";
pidi sorted kootam = bubbleSort(data);

para "Sorted Array:";
para sorted;

para "\nSearching value 7";
pidi index = binarySearch(sorted,7);

nok index == -1 {
    para "Value not found\n";
}
:umbi{
    para "Found at index:";
    para index koode "\n";
};

para "\nArray Sum:";
para arraySum(sorted);

para "\nFibonacci Sequence:";
pidi i = 0;

ittuthiri i < 8 {
    para fib(i) koode "\n";
    i = i + 1;
}
