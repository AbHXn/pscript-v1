pari parseJSON(pidi str){
    pidi keys kootam = {};
    pidi values kootam = {};

    pidi key = "";
    pidi value = "";

    pidi readingKey = sheri;
    pidi readingString = thettu;

    pidi i = 0;
    pidi index = 0;

    ittuthiri i < str:kanam {
        pidi ch = str[i];
        para ch koode "\n";

        nok ch == "\"" {
            nok readingString {
                readingString = thettu;
            }: umbi {
                readingString = sheri;
            };
            i = i + 1;
            pinnava;
        };

        nok readingString {
            nok readingKey {
                key = key + ch;
            }: umbi {
                value = value + ch;
            };
            i = i + 1;
            pinnava;
        };

        nok ch == ":" {
            readingKey = thettu;
            i = i + 1;
            pinnava;
        };

        nok ch == "," yo ch == "}" {
            nok key:kanam > 0 {
                keys[index] = key;
                values[index] = value;

                key = "";
                value = "";
                readingKey = sheri;
                index = index + 1;
            };
            i = i + 1;
            pinnava;
        };
        i = i + 1;
    }
    pidi result kootam = {};
    result[0] = keys;
    result[1] = values;

    poda result;
}

pidi json = "{\"name\":\"Alice\",\"age\":\"25\"}";

pidi result kootam = parseJSON(json);

para "Keys:\n";
para result[0] koode "\n";

para "Values:\n";
para result[1] koode "\n";
