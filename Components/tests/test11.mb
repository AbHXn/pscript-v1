thenga merge(pidi arr kootam, pidi l, pidi m, pidi r){
    pidi i = l;
    pidi j = m + 1;
    pidi k = 0;

    pidi temp kootam = {0};

    ittuthiri i <= m um j <= r {
        nok arr[i] <= arr[j] {
            temp[k] = arr[i];
            i = i + 1;
        } :umbi {
            temp[k] = arr[j];
            j = j + 1;
        };
        k = k + 1;
    }

    ittuthiri i <= m {
        temp[k] = arr[i];
        i = i + 1;
        k = k + 1;
    }

    ittuthiri j <= r {
        temp[k] = arr[j];
        j = j + 1;
        k = k + 1;
    }

    pidi t = 0;
    ittuthiri t < k {
        arr[l + t] = temp[t];
        t = t + 1;
    }
}

thenga mergesort(pidi arr kootam, pidi l, pidi r){
    nok l < r {
        pidi m = (l + r) / 2;
		m := INT;
        mergesort(arr, l, m);
        mergesort(arr, m + 1, r);
        merge(arr, l, m, r);
    };
}

pidi arr kootam = {0};
arr[0] = 10; arr[1] = 7; arr[2] = 8; arr[3] = 9; arr[4] = 1; arr[5] = 5;

mergesort(arr, 0, 5);

pidi i = 0;
ittuthiri i < 6 {
    para arr[i] koode "\n";
    i = i + 1;
}
