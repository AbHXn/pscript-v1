pidi x kootam = {1, 4, 6, 8, 10, 23};
pidi start, end = 0, x:valupam - 1;
pidi search = 23;

ittuthiri start <= end {
	pidi mid = (start + end) / 2;
	mid := INT;
	nok x[mid] == search {
		para "Element found at" koode mid koode "\n";
		theku;
	}: nok x[mid] > search {
		end = mid - 1;
	}: umbi {
		start = mid + 1;
	};
}
