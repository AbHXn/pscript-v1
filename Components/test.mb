thenga test(pidi optr){
	thenga sum(pidi arr kootam){
		pidi index, total = 0, arr:valupam;
		pidi sum = 0;		
		ittuthiri index < total {
			sum = sum + arr[index];
			index = index + 1;		
		}
		poda sum;
	}
	thenga sub(pidi arr kootam){
		pidi index, total = 0, arr:valupam;
		pidi sum = 0;
		ittuthiri index < total {
			sum = sum - arr[index];
			index = index + 1;		
		}
		poda sum;
	}
	nok optr == "+" {
		poda sum;	
	}: nok optr == "-" {
		poda sub;		
	}: umbi {
		poda "not defined";
	};
}

pidi x = "-";
pidi func_returned = test(x);
pidi arr kootam = {1, 20, 23, 4};
pidi res = func_returned(arr);
para res koode "\n";